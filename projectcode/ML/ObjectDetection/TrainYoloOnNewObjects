def download_with_progress(url: str, out_path: Path):
    out_path.parent.mkdir(parents=True, exist_ok=True)
    if out_path.exists() and out_path.stat().st_size > 0:
        return
    with requests.get(url, stream=True) as r:
        r.raise_for_status()
        total = int(r.headers.get("content-length", 0))
        with tqdm(total=total, unit="B", unit_scale=True, desc=out_path.name) as pbar:
            with open(out_path, "wb") as f:
                for chunk in r.iter_content(1024 * 1024):
                    if chunk:
                        f.write(chunk)
                        pbar.update(len(chunk))

def unzip(zip_path: Path, dest_dir: Path):
    dest_dir.mkdir(parents=True, exist_ok=True)
    with zipfile.ZipFile(zip_path, "r") as z:
        z.extractall(dest_dir)

def ensure_coco_val_present():
    ZIPS_DIR.mkdir(parents=True, exist_ok=True)
    vzip = ZIPS_DIR / "val2017.zip"
    azip = ZIPS_DIR / "annotations_trainval2017.zip"

    # Download only val + annotations
    download_with_progress(COCO["val_images"], vzip)
    download_with_progress(COCO["ann"], azip)

    # Unzip idempotently (do NOT delete underlying folder)
    if not VAL_DIR.exists():
        unzip(vzip, COCO_ROOT)
    if not ANN_DIR.exists():
        unzip(azip, COCO_ROOT)

    # Check
    missing = []
    if not VAL_DIR.exists():            missing.append(str(VAL_DIR))
    if not VAL_JSON.exists():           missing.append(str(VAL_JSON))
    if missing:
        raise FileNotFoundError(f"COCO val incomplete: {missing}")

def pick_random_val_ids(keep_n: int, seed: int) -> Set[int]:
    with open(VAL_JSON, "r") as f:
        coco = json.load(f)
    ids = [img["id"] for img in coco["images"]]
    if keep_n >= len(ids):  # 5000
        return set(ids)
    rng = random.Random(seed)
    rng.shuffle(ids)
    return set(ids[:keep_n])

def coco_to_yolo_txts(coco_json: Path, images_dir: Path, out_labels_dir: Path, out_images_dir: Path, keep_image_ids: Optional[Set[int]] = None):
    out_labels_dir.mkdir(parents=True, exist_ok=True)
    out_images_dir.mkdir(parents=True, exist_ok=True)

    with open(coco_json, "r") as f:
        coco = json.load(f)

    imgs_by_id = {img["id"]: img for img in coco["images"]}
    anns_by_img = {}
    for ann in coco["annotations"]:
        if ann.get("iscrowd", 0) == 1:
            continue
        img_id = ann["image_id"]
        if keep_image_ids is not None and img_id not in keep_image_ids:
            continue
        anns_by_img.setdefault(img_id, []).append(ann)

    image_ids = list(imgs_by_id.keys())
    if keep_image_ids is not None:
        image_ids = [i for i in image_ids if i in keep_image_ids]

    created = 0
    for img_id in tqdm(image_ids, desc=f"Converting {coco_json.stem}"):
        info = imgs_by_id[img_id]
        file_name = info["file_name"]
        w, h = info["width"], info["height"]

        src = images_dir / file_name
        if not src.exists():
            continue

        dst = out_images_dir / file_name
        if not dst.exists():
            shutil.copy2(src, dst)

        label_path = out_labels_dir / (Path(file_name).stem + ".txt")
        anns = anns_by_img.get(img_id, [])
        lines = []
        for ann in anns:
            cid = ann["category_id"]
            if cid not in COCO_ID_TO_IDX:
                continue
            cls = COCO_ID_TO_IDX[cid]
            x, y, bw, bh = ann["bbox"]
            cx = (x + bw / 2) / w
            cy = (y + bh / 2) / h
            nw = bw / w
            nh = bh / h
            if nw <= 0 or nh <= 0:
                continue
            cx = min(max(cx, 0.0), 1.0)
            cy = min(max(cy, 0.0), 1.0)
            nw = min(max(nw, 0.0), 1.0)
            nh = min(max(nh, 0.0), 1.0)
            lines.append(f"{cls} {cx:.6f} {cy:.6f} {nw:.6f} {nh:.6f}")
        with open(label_path, "w") as lf:
            lf.write("\n".join(lines))
        created += 1
    return created

def safe_rebuild_generated_dirs():
    """Clear only generated outputs (images/, labels/, YAML). NEVER delete _coco."""
    for t in [OUT_IMG_VAL.parent, OUT_LBL_VAL.parent, COMBINED_YAML]:
        if t.exists():
            if t.is_dir():
                shutil.rmtree(t)
            else:
                t.unlink()

def ensure_waterfilter_label_ids_are_80(root: Path):
    """
    Recursively fix YOLO label files under `root/labels/*/*.txt`:
    If a line starts with '0 ' assume it means WaterFilter and rewrite to '80 '.
    If labels already 80, leave as is. Ignores empty files.
    """
    lbl_dir = root / "labels"
    if not lbl_dir.exists():
        print(f"[Warn] No labels directory found at {lbl_dir}. Skipping remap.")
        return
    txts = list(lbl_dir.rglob("*.txt"))
    if not txts:
        print(f"[Warn] No .txt labels found under {lbl_dir}.")
        return

    changed = 0
    for p in txts:
        with open(p, "r") as f:
            lines = f.readlines()
        new_lines = []
        updated = False
        for line in lines:
            if not line.strip():
                continue
            # Replace a leading class id (integer) followed by space
            m = re.match(r"^(\d+)\s+(.*)$", line.strip())
            if m:
                cls = int(m.group(1))
                rest = m.group(2)
                if cls == 0:  # common "single-class = 0" pattern
                    new_lines.append(f"80 {rest}\n")
                    updated = True
                else:
                    new_lines.append(line if line.endswith("\n") else line + "\n")
            else:
                new_lines.append(line if line.endswith("\n") else line + "\n")
        if updated:
            with open(p, "w") as f:
                f.writelines(new_lines)
            changed += 1
    print(f"[Info] WaterFilter label remap complete. Files updated: {changed}")

def make_symlinked_clone(src: Path, dst: Path):
    """
    Create a shallow symlinked clone of a dataset split folder (images/, labels/).
    Keeps filenames identical; only directories are duplicated as new symlink targets.
    """
    if dst.exists():
        shutil.rmtree(dst)
    for sub in ["images/train", "labels/train"]:
        s = src / sub
        d = dst / sub
        d.mkdir(parents=True, exist_ok=True)
        if s.exists():
            for f in s.iterdir():
                os.symlink(f, d / f.name)

def build_combined_yaml(paths_train: Iterable[str], paths_val: Iterable[str], out_yaml: Path):
    names = YOLO_80 + ["water_filter"]  # index 80
    text = "path: /\ntrain:\n"
    for p in paths_train:
        text += f"  - {p}\n"
    text += "val:\n"
    for p in paths_val:
        text += f"  - {p}\n"
    text += "names:\n"
    for n in names:
        text += f"  - {n}\n"
    out_yaml.write_text(text)
    print(f"[OK] Wrote combined YAML → {out_yaml}")

def main_prepare():
    print("[Step] Ensuring COCO val present…")
    ensure_coco_val_present()

    print("[Step] Sampling val ids & converting to YOLO…")
    keep_ids = pick_random_val_ids(VAL_KEEP, SEED)
    safe_rebuild_generated_dirs()  # only clears generated stuff; keeps _coco
    created = coco_to_yolo_txts(VAL_JSON, VAL_DIR, OUT_LBL_VAL, OUT_IMG_VAL, keep_ids)
    print(f"[OK] COCO val YOLO set ready: {created} images")

    print("[Step] Validating/remapping WaterFilter labels to class id 80…")
    ensure_waterfilter_label_ids_are_80(WATERFILTER_ROOT)

    # Optional oversampling via symlinked clones
    wf_train = WATERFILTER_ROOT / "images" / "train"
    wf_lbl   = WATERFILTER_ROOT / "labels" / "train"
    if not wf_train.exists() or not wf_lbl.exists():
        print(f"[WARN] WaterFilter train split not found at {wf_train} / {wf_lbl}.")
    clone_paths = []
    if OVERSAMPLE_COPIES > 0:
        print(f"[Step] Creating {OVERSAMPLE_COPIES} symlinked oversample clones…")
        base = WATERFILTER_ROOT
        for i in range(1, OVERSAMPLE_COPIES + 1):
            clone = base.parent / f"{base.name}_oversample_{i}"
            make_symlinked_clone(base, clone)
            clone_paths.append(str(clone / "images" / "train"))
        print(f"[OK] Oversample clones: {clone_paths}")

    # Build combined YAML
    # - train uses COCO val + WF train (+ any clones)
    # - val uses COCO val + WF val (fallback to WF train if val missing)
    wf_images_train = WATERFILTER_ROOT / "images" / "train"
    wf_images_val = WATERFILTER_ROOT / "images" / "val"
    wf_labels_val = WATERFILTER_ROOT / "labels" / "val"

    if not wf_images_val.exists() or not wf_labels_val.exists():
        print(f"[INFO] WaterFilter val split not found at {wf_images_val} or {wf_labels_val}. Reusing train split as val.")
        wf_val_for_yaml = wf_images_train
    else:
        wf_val_for_yaml = wf_images_val

    train_paths = [
        str(OUT_IMG_VAL),  # COCO rehearsal as train too
        str(wf_images_train),
    ] + clone_paths
    val_paths = [
        str(OUT_IMG_VAL),  # COCO for old-class retention check
        str(wf_val_for_yaml),
    ]
    build_combined_yaml(train_paths, val_paths, COMBINED_YAML)

def main_train():
    print("[Step] Starting Ultralytics training…")
    from ultralytics import YOLO

    # Phase 1: freeze early backbone, learn new head
    model = YOLO(MODEL_WEIGHTS)
    model.train(
        data=str(COMBINED_YAML),
        epochs=EPOCHS_MAIN,
        imgsz=IMGSZ,
        batch=BATCH,
        lr0=LR0_MAIN,
        weight_decay=5e-4,
        momentum=0.937,
        freeze=FREEZE_MAIN,
        patience=15,
        cos_lr=True,
        mosaic=1.0,
        mixup=0.15,
        copy_paste=0.30,
        close_mosaic=10,
        cache="ram",
        project="/app/mediaFiles/images/YoloTrainingImages/ModelWeightsYolo",
        name="coco_plus_waterfilter"
    )

    # Phase 2 (optional): unfreeze a bit and fine-tune at lower LR
    last = getattr(model, "ckpt_path", None)
    ckpt = last or "/app/mediaFiles/images/YoloTrainingImages/ModelWeightsYolo/coco_plus_waterfilter/weights/last.pt"
    print(f"[Step] Fine-tuning from: {ckpt}")
    model = YOLO(ckpt)
    model.train(
        data=str(COMBINED_YAML),
        epochs=EPOCHS_FINETUNE,
        imgsz=IMGSZ,
        batch=BATCH,
        lr0=LR0_FT,
        freeze=FREEZE_FT,
        patience=10,
        cos_lr=True,
        project="/app/mediaFiles/images/YoloTrainingImages/ModelWeightsYolo",
        name="coco_plus_waterfilter_finetune"
    )

    print("[DONE] Training complete. Check runs/detect/* for results.")

if __name__ == "__main__":
    main_prepare()
    main_train()
