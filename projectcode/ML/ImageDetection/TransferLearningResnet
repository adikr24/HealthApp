import torch
import torch.nn as nn
from torchvision import models, transforms
from PIL import Image

# --- CONFIG ---
checkpoint_path = "/app/projectcode/ModelCheckpointsAndLabels/resnet50_food101_plus_newclasses.pth"
image_path = "/app/mediaFiles/images/inputimages/foodimages/coffee_V.jpg"  # replace with your test image path

# Device
device = torch.device("cuda" if torch.cuda.is_available() else "cpu")

# --- LOAD LABELS ---
with open("/app/projectcode/ModelCheckpointsAndLabels/resnet_101_labels.txt", "r") as f:
    labels = [line.strip() for line in f.readlines()]

# Add new classes matching training order: coffee, blackcoffee, banana
labels += ["coffee", "blackcoffee", "banana"]

assert len(labels) == 104, "Label list length must match model output classes!"

# --- LOAD MODEL ---
model = models.resnet50(weights=None)
num_ftrs = model.fc.in_features
model.fc = nn.Linear(num_ftrs, 104)
model.load_state_dict(torch.load(checkpoint_path, map_location=device))
model = model.to(device)
model.eval()

# --- IMAGE TRANSFORM ---
transform = transforms.Compose([
    transforms.Resize(256),
    transforms.CenterCrop(224),
    transforms.ToTensor(),
    transforms.Normalize(mean=[0.485,0.456,0.406], std=[0.229,0.224,0.225])
])

# --- LOAD IMAGE ---
img = Image.open(image_path).convert("RGB")
input_tensor = transform(img).unsqueeze(0).to(device)  # add batch dimension and send to device

# --- PREDICTION ---
with torch.no_grad():
    outputs = model(input_tensor)
    probs = torch.softmax(outputs, dim=1)
    confidence, pred_idx = torch.max(probs, dim=1)
    pred_label = labels[pred_idx.item()]

print(f"Predicted class: {pred_label}")
print(f"Confidence: {confidence.item():.4f}")

# --- TOP-5 PREDICTIONS ---
topk = torch.topk(probs, 5)
print("\nTop-5 predictions:")
for i in range(5):
    idx = topk.indices[0][i].item()
    prob = topk.values[0][i].item()
    label = labels[idx] if idx < len(labels) else "Unknown"
    print(f"{label}: {prob:.4f}")

# --- FC LAYER INFO ---
state_dict = torch.load(checkpoint_path, map_location=device)
print("\nFC layer weight shape:", state_dict["fc.weight"].shape)
print("FC layer bias shape:", state_dict["fc.bias"].shape)
