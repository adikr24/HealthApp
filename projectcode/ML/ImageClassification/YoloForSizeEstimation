import cv2
from ultralytics import YOLO
import os

def run_yolov8_detection(image_path, model_name='yolov8n.pt', confidence_threshold=0.25, output_dir='/app/mediaFiles/images/labeledimages/'):
    """
    Runs YOLOv8 object detection on a specified image and saves the results.

    Args:
        image_path (str): Path to the input image.
        model_name (str): Name of the YOLOv8 model to use (e.g., 'yolov8n.pt', 'yolov8s.pt').
                          Can also be the path to a custom trained model ('path/to/best.pt').
        confidence_threshold (float): Minimum confidence score for a detection to be considered.
        output_dir (str): Directory where annotated images and detection labels will be saved.
    """
    try:
        # Load a pretrained YOLOv8 model
        # The first time you run this, it might download the model weights to the ultralytics cache.
        model = YOLO(model_name)

        # Ensure the output directory exists
        os.makedirs(output_dir, exist_ok=True)

        # Perform inference on the image
        # save=True saves the annotated image
        # save_txt=True saves the bounding box labels in YOLO format
        # project=output_dir specifies the base directory for saving results
        results = model.predict(image_path, conf=confidence_threshold, save=True, save_txt=True, project=output_dir)

        # Process and display results (optional, can be commented out for server environments)
        for r in results:
            print(f"--- Detections for {os.path.basename(image_path)} ---")
            # Print bounding box information
            for box in r.boxes:
                class_id = int(box.cls[0])
                label = model.names[class_id]
                confidence = float(box.conf[0])
                bbox_xyxy = box.xyxy[0].tolist() # Convert tensor to list [x1, y1, x2, y2]

                print(f"  Object: {label}, Confidence: {confidence:.2f}, Bounding Box: {bbox_xyxy}")

            # Display the annotated image if running with a GUI (like VS Code Dev Container with X-forwarding or desktop environment)
            annotated_image = r.plot() # 'plot()' returns an image with detections drawn on it
            cv2.imshow("YOLOv8 Detection", annotated_image)
            cv2.waitKey(0) # Wait indefinitely until a key is pressed
            cv2.destroyAllWindows() # Close all OpenCV windows

            # Confirm where results are saved
            print(f"Annotated image and labels saved to: {r.save_dir}")

    except FileNotFoundError:
        print(f"Error: Image file not found at '{image_path}'")
    except Exception as e:
        print(f"An error occurred during YOLO detection: {e}")

if __name__ == "__main__":
    # --- Configuration ---
    # Path to your input image within the container's file system.
    # If mounted from Windows C:\Users\adity\OneDrive\Desktop\Aditya\StartupIdeas\HealthMonitor\my_project_code,
    # and the image is in that folder, then the path is just "test_image.jpg"
    # because the script will be run from /app/code after 'cd /app/code'.
    # If the image is in a subfolder like 'my_project_code/generated_images/image1.png',
    # then the path would be "generated_images/image1.png".
    input_image_path = "/app/mediaFiles/images/inputimages/frame_126.jpg"

    # You can choose different pre-trained models: 'yolov8n.pt' (nano), 'yolov8s.pt' (small), etc.
    # Or load your own custom-trained model: 'path/to/best.pt'
    yolov8_model = 'yolov8n.pt' # Using the nano model as a default

    # Minimum confidence score for displaying a detection (0.0 to 1.0)
    detection_confidence = 0.5

    # Output directory for saving results (relative to the script's execution directory, /app/code)
    output_directory = "yolo_results"

    # --- Run Detection ---
    run_yolov8_detection(input_image_path, yolov8_model, detection_confidence, output_directory)
