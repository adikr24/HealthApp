#!/usr/bin/env python3
# add_hand_rois_inside.py
# - NO merging here (assumes previous pass already produced left_hand/right_hand/merged_hands or hand+hand_side)
# - Builds "hand ROI" rectangles INSIDE each hand/merged bbox, hugging the finger-side/top as specified.
# - Groups by frame to avoid per-row overwrite; saves one annotated image per frame.
# - Augments CSV with hand_roi_* fields.

from pathlib import Path
import csv, cv2, re
from collections import Counter, defaultdict

# ======================= PATHS =======================

BASE_SECOND = Path("/app/mediaFiles/output/videoOutputs/ProteinShake/CookingAnalysis/SecondPass_GenerateMovementMetadata")
BASE_FIRST  = Path("/app/mediaFiles/output/videoOutputs/ProteinShake/CookingAnalysis/FirstPass_ImageAnnotation/CustomYolo/detailed_hand_sides")

# Inputs (priority order)
CANDIDATE_LABELS = [
    BASE_SECOND / "Metadata" / "HandActivity" / "hand_label_collapse.csv",  # NEW location
    BASE_SECOND / "Metadata" / "voi_bbox_and_hands_labels.csv",
    BASE_FIRST  / "all_detections_with_hand_side.csv",
]

# Images: read from VOI overlays if available, else from source frames
VOI_IMG_DIR = BASE_SECOND / "bounding_boxes" / "VOIBoundingBoxes"
SRC_IMG_DIR = BASE_FIRST

# Outputs
OUT_META_DIR = BASE_SECOND / "Metadata" / "HandActivity"   # <— new subfolder for hand activity
OUT_IMG_DIR  = BASE_SECOND / "bounding_boxes" / "HandROIs" # same as before
OUT_CSV      = OUT_META_DIR / "hand_rois.csv"

OUT_META_DIR.mkdir(parents=True, exist_ok=True)
OUT_IMG_DIR.mkdir(parents=True, exist_ok=True)
# ======================= CONFIG =======================

# Labels to accept as "already-merged components"
HAND_COMPONENT_LABELS = {"left_hand", "right_hand", "unknown_hand", "merged_hands"}

# ROI sizing (inside hand box)
W_FRAC = 0.30            # width fraction
H_FRAC = 0.30            # height fraction
SIDE_INSET_FRAC = 0.02   # small inward pad from side edges
TOP_INSET_FRAC  = 0.02   # small inward pad from top edge
MIN_PX = 6               # minimum ROI dimension (after clamping)

# For merged_hands (top-center band) trims
MERGED_TRIM_LEFT_FRAC  = 0.15
MERGED_TRIM_RIGHT_FRAC = 0.15

# Drawing
HAND_ROI_COLOR = (255, 200, 0)  # BGR (cyan-ish)
HAND_BOX_COLOR = (60, 200, 255) # faint original hand box (optional)
THICK          = 2
FONT = cv2.FONT_HERSHEY_SIMPLEX
TSCALE = 0.5
TTHICK = 1

# ======================= HELPERS =======================

def norm(s): 
    return (s or "").strip().lower()

def pick_input_csv():
    for p in CANDIDATE_LABELS:
        if p.exists():
            print(f"[INFO] Using input labels: {p}")
            return p
    raise FileNotFoundError(f"No input labels found. Checked: {CANDIDATE_LABELS}")

def frame_idx(name):
    m = re.search(r"(\d+)", Path(name).stem)
    return int(m.group(1)) if m else -1

def clamp(v, lo, hi):
    return max(lo, min(hi, v))

def row_to_hand_label_and_box(row):
    """
    Normalize to (label, box) for hand components.
    Priority:
      1) 'label' column (from collapse): left_hand/right_hand/merged_hands/unknown_hand
      2) class columns if they already encode those labels
      3) raw hand + 'hand_side' -> left_hand/right_hand
    """
    # 1) collapse format
    lbl = norm(row.get("label"))
    if lbl in HAND_COMPONENT_LABELS:
        try:
            x1 = float(row["x1"]); y1 = float(row["y1"])
            x2 = float(row["x2"]); y2 = float(row["y2"])
            return lbl, (x1,y1,x2,y2)
        except:
            return None, None

    # 2) unified/raw with class names already as components
    cls = norm(row.get("cls_name_norm") or row.get("cls_name") or row.get("cls_name_orig"))
    if cls in HAND_COMPONENT_LABELS:
        try:
            x1 = float(row["x1"]); y1 = float(row["y1"])
            x2 = float(row["x2"]); y2 = float(row["y2"])
            return cls, (x1,y1,x2,y2)
        except:
            return None, None

    # 3) raw: "hand" + hand_side
    if cls == "hand":
        side = norm(row.get("hand_side"))
        if side in ("left","right"):
            lbl = f"{side}_hand"
            try:
                x1 = float(row["x1"]); y1 = float(row["y1"])
                x2 = float(row["x2"]); y2 = float(row["y2"])
                return lbl, (x1,y1,x2,y2)
            except:
                return None, None

    return None, None

def hand_roi_inside(label: str, box):
    """
    Build a hand ROI INSIDE the given hand/merged bbox, hugging top + side:
      - left_hand  : top-right inside
      - right_hand : top-left inside
      - unknown_hand: top-center inside
      - merged_hands: top-center band inside, trimmed on sides
    Returns (rx1, ry1, rx2, ry2) ints or None if invalid/tiny.
    """
    x1,y1,x2,y2 = map(float, box)
    w = max(0.0, x2 - x1)
    h = max(0.0, y2 - y1)
    if w < 2*MIN_PX or h < 2*MIN_PX:
        return None

    rw = max(MIN_PX, W_FRAC * w)
    rh = max(MIN_PX, H_FRAC * h)
    padL = SIDE_INSET_FRAC * w
    padR = SIDE_INSET_FRAC * w
    padT = TOP_INSET_FRAC  * h

    if label == "left_hand":
        # top-right inside
        rx2 = x2 - padR;    rx1 = rx2 - rw
        ry1 = y1 + padT;    ry2 = ry1 + rh

    elif label == "right_hand":
        # top-left inside
        rx1 = x1 + padL;    rx2 = rx1 + rw
        ry1 = y1 + padT;    ry2 = ry1 + rh

    elif label == "merged_hands":
        # top-center band inside, trimmed on sides
        rx1 = x1 + MERGED_TRIM_LEFT_FRAC  * w
        rx2 = x2 - MERGED_TRIM_RIGHT_FRAC * w
        if (rx2 - rx1) < rw:  # if too narrow, use centered rw
            cx = (x1 + x2) / 2.0
            rx1, rx2 = cx - rw/2.0, cx + rw/2.0
        ry1 = y1 + padT;    ry2 = ry1 + rh

    else:  # unknown_hand → top-center
        cx = (x1 + x2) / 2.0
        rx1, rx2 = cx - rw/2.0, cx + rw/2.0
        ry1 = y1 + padT;    ry2 = ry1 + rh

    # Clamp inside hand bbox (float)
    rx1 = clamp(rx1, x1, x2);  rx2 = clamp(rx2, x1, x2)
    ry1 = clamp(ry1, y1, y2);  ry2 = clamp(ry2, y1, y2)

    # Enforce minimum size AFTER clamp (slide if needed)
    if (rx2 - rx1) < MIN_PX:
        rx2 = clamp(rx1 + MIN_PX, x1, x2)
        rx1 = clamp(rx2 - MIN_PX, x1, x2)
    if (ry2 - ry1) < MIN_PX:
        ry2 = clamp(ry1 + MIN_PX, y1, y2)
        ry1 = clamp(ry2 - MIN_PX, y1, y2)

    if rx2 <= rx1 or ry2 <= ry1:
        return None

    return tuple(int(round(v)) for v in (rx1, ry1, rx2, ry2))

# ======================= MAIN =======================

def main():
    in_csv = pick_input_csv()

    with in_csv.open("r", newline="") as f:
        rdr = csv.DictReader(f)
        rows = list(rdr)
        fields = rdr.fieldnames or []

    # quick sanity
    def seen_label(r):
        return norm(r.get("label") or r.get("cls_name_norm") or r.get("cls_name") or r.get("cls_name_orig"))
    print("[DEBUG] Label/Class counts:", dict(Counter(seen_label(r) for r in rows)))

    # Prepare output header = original + hand_roi_*
    extra_cols = ["hand_roi_x1","hand_roi_y1","hand_roi_x2","hand_roi_y2",
                  "hand_roi_cx","hand_roi_cy","hand_roi_w","hand_roi_h"]
    out_fields = list(fields)
    for c in extra_cols:
        if c not in out_fields:
            out_fields.append(c)

    # Group rows by frame (avoid per-row overwrite)
    by_frame = defaultdict(list)
    for r in rows:
        fname = Path(r.get("frame") or "").name
        if fname:
            by_frame[fname].append(r)

    use_voi_imgs = VOI_IMG_DIR.exists()

    out_rows = []

    for fname in sorted(by_frame, key=frame_idx):
        # load once
        src_img_dir = VOI_IMG_DIR if use_voi_imgs else SRC_IMG_DIR
        img_path = src_img_dir / fname
        img = cv2.imread(str(img_path)) if img_path.exists() else None

        # process all rows for this frame
        for r in by_frame[fname]:
            out = dict(r)
            for c in extra_cols: 
                out.setdefault(c, "")

            # get hand component
            lbl, box = row_to_hand_label_and_box(r)
            if lbl and box:
                hroi = hand_roi_inside(lbl, box)
                if hroi:
                    rx1, ry1, rx2, ry2 = hroi
                    rcx = (rx1 + rx2) // 2
                    rcy = (ry1 + ry2) // 2
                    rw  = (rx2 - rx1)
                    rh  = (ry2 - ry1)
                    out.update({
                        "hand_roi_x1": rx1, "hand_roi_y1": ry1,
                        "hand_roi_x2": rx2, "hand_roi_y2": ry2,
                        "hand_roi_cx": rcx, "hand_roi_cy": rcy,
                        "hand_roi_w": rw,   "hand_roi_h": rh
                    })

                    if img is not None:
                        # (optional) faint original hand bbox
                        try:
                            bx1,by1,bx2,by2 = map(int, [float(r["x1"]),float(r["y1"]),float(r["x2"]),float(r["y2"])])
                            cv2.rectangle(img, (bx1,by1), (bx2,by2), HAND_BOX_COLOR, 1)
                            cv2.putText(img, lbl, (bx1, max(10,by1-6)), FONT, TSCALE, HAND_BOX_COLOR, 1, cv2.LINE_AA)
                        except:
                            pass
                        # draw ROI
                        cv2.rectangle(img, (rx1,ry1), (rx2,ry2), HAND_ROI_COLOR, THICK)
                        cv2.putText(img, "hand-ROI", (rx1, max(10, ry1-6)), FONT, TSCALE, HAND_ROI_COLOR, TTHICK, cv2.LINE_AA)

            out_rows.append(out)

        # save once per frame (after drawing all hands)
        if img is not None:
            OUT_IMG_DIR.mkdir(parents=True, exist_ok=True)
            cv2.imwrite(str(OUT_IMG_DIR / fname), img)

    # write CSV
    with OUT_CSV.open("w", newline="") as f:
        w = csv.DictWriter(f, fieldnames=out_fields)
        w.writeheader()
        w.writerows(out_rows)

    print(f"[DONE] Hand ROIs CSV → {OUT_CSV}")
    print(f"[DONE] Annotated frames → {OUT_IMG_DIR}")

if __name__ == "__main__":
    main()
